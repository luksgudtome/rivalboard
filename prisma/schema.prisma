generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StageType {
  single_elimination
  double_elimination
  round_robin
}

enum TournamentFormat {
  rr_se
  rr_de
  se
  de
}

enum TournamentGameType {
  esports
  basketball
  football
  volleyball
  badminton
  tennis
  chess
  other
}

enum SubscriptionPlan {
  free
  pro
}

model User {
  id                       String           @id @default(cuid())
  name                     String
  email                    String           @unique
  passwordHash             String
  plan                     SubscriptionPlan @default(free)
  paypalSubscriptionId     String?          @unique
  paypalSubscriptionStatus String?
  paypalPlanId             String?
  paypalPayerId            String?
  billingUpdatedAt         DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  tournaments              Tournament[]
}

model Tournament {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  description String   @default("")
  gameType    TournamentGameType @default(esports)
  format      TournamentFormat   @default(se)
  type       StageType
  isPublic   Boolean   @default(false)
  stageId    Int
  data       Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@index([userId, updatedAt(sort: Desc)]) 
}
